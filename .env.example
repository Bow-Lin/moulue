LLM_PROVIDER=fake

# To use GLM, switch LLM_PROVIDER to glm and fill these values.
# LLM_PROVIDER=glm
# GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# GLM_MODEL=glm-4.5-flash

# To use Bailian, switch LLM_PROVIDER to bailian and fill these values.
# LLM_PROVIDER=bailian
# BAILIAN_API_KEY=
# BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# BAILIAN_MODEL=qwen-plus
